---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---
<Layout title="Seite nicht gefunden" description="Die aufgerufene Seite wurde nicht gefunden.">
  <div class="not-found">
    <div class="not-found-inner">
      <p class="not-found-kanji">空</p>
      <h1>404</h1>
      <p class="not-found-msg">Diese Seite wurde nicht gefunden.</p>
      <a href={base} class="back-link">← Zur Startseite</a>
    </div>
  </div>
</Layout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
  }
  .not-found-inner {
    text-align: center;
  }
  .not-found-kanji {
    font-size: 5rem;
    color: var(--primary);
    opacity: 0.2;
    line-height: 1;
    margin-bottom: 1rem;
  }
  h1 {
    font-size: 4rem;
    font-weight: 900;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .not-found-msg {
    color: var(--text-muted);
    margin-bottom: 2rem;
    font-size: 1.1rem;
  }
  .back-link {
    display: inline-block;
    background: var(--primary);
    color: #fff;
    padding: 0.75rem 1.75rem;
    border-radius: 6px;
    font-weight: 600;
    font-family: var(--font-head);
    transition: background 0.15s;
  }
  .back-link:hover { background: var(--primary-dark); }
</style>
