---
import Layout from '../../layouts/Layout.astro';
import { techniken, kategoriefarben, type Kategorie } from '../../data/techniken';
import { toRomanisch } from '../../utils/romanisch';
const base = import.meta.env.BASE_URL;
const kategorien: Kategorie[] = ['Tsuki', 'Uke', 'Geri', 'Uchi'];
const katNames: Record<Kategorie, string> = { Tsuki: 'Stöße', Uke: 'Blöcke', Geri: 'Tritte', Uchi: 'Schläge' };
---
<Layout title="Kihon – Grundtechniken" description="Alle Shotokan Grundtechniken: Stöße (Tsuki), Blöcke (Uke), Tritte (Geri) und Schläge (Uchi) mit Ausführungsbeschreibung.">
  <div class="page-header">
    <div class="page-header-inner">
      <p class="breadcrumb"><a href={base}>Startseite</a> <span class="sep">›</span> Kihon</p>
      <h1><span class="jp">基本</span> Kihon</h1>
      <p class="subtitle">Grundtechniken · {techniken.length} Techniken · JKA Shotokan</p>
    </div>
  </div>

  <div class="container">
    <div class="filter-bar" id="filter-bar">
      <button class="filter-btn active" data-kat="alle">Alle ({techniken.length})</button>
      {kategorien.map(k => (
        <button class="filter-btn" data-kat={k}>
          {k} – {katNames[k]} ({techniken.filter(t => t.kategorie === k).length})
        </button>
      ))}
    </div>

    <div class="grid-3" id="technik-grid">
      {techniken.map(t => (
        <a href={`${base}kihon/${t.id}`} class="card technik-card" data-kat={t.kategorie}>
          <div class="card-top">
            <span class="badge" style={`background: ${kategoriefarben[t.kategorie]}`}>{t.kategorie}</span>
            <span class="schwierigkeit">{t.schwierigkeit}</span>
          </div>
          <p class="technik-jp">{t.nameJP} <span class="romanisch">({toRomanisch(t.id)})</span></p>
          <h2 class="technik-name">{t.nameDE}</h2>
          <p class="technik-desc">{t.beschreibung.slice(0, 100)}…</p>
          <p class="technik-kyu">Prüfungsrelevant ab {t.kyu}. Kyu</p>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; }
  .schwierigkeit { font-size: 0.75rem; color: var(--text-muted); }
  .technik-jp { font-size: 1.5rem; color: var(--primary); margin-bottom: 0.25rem; line-height: 1; }
  .technik-name { font-size: 1.05rem; margin-bottom: 0.75rem; }
  .technik-desc { font-size: 0.875rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 0.75rem; }
  .technik-kyu { font-size: 0.8rem; color: var(--text-muted); font-weight: 500; }
  .technik-card[hidden] { display: none; }
</style>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('#filter-bar .filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('#technik-grid .technik-card');
  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const kat = btn.dataset.kat;
      cards.forEach(card => { card.hidden = kat !== 'alle' && card.dataset.kat !== kat; });
    });
  });
</script>
