---
import Layout from '../../layouts/Layout.astro';
import { techniken, kategoriefarben } from '../../data/techniken';
import { toRomanisch } from '../../utils/romanisch';
import KihonIllustration from '../../components/KihonIllustration.astro';

export function getStaticPaths() {
  return techniken.map(t => ({ params: { id: t.id }, props: { technik: t } }));
}

const { technik } = Astro.props;
const base = import.meta.env.BASE_URL;
const verwandte = techniken.filter(t => t.kategorie === technik.kategorie && t.id !== technik.id).slice(0, 3);
---
<Layout title={`${technik.nameDE} (${technik.nameJP})`} description={technik.beschreibung}>
  <div class="page-header">
    <div class="page-header-inner">
      <p class="breadcrumb">
        <a href={base}>Startseite</a>
        <span class="sep">›</span>
        <a href={`${base}kihon`}>Kihon</a>
        <span class="sep">›</span>
        {technik.nameDE}
      </p>
      <h1>{technik.nameJP} <span class="romanisch">({toRomanisch(technik.id)})</span></h1>
      <p class="subtitle">{technik.nameDE}</p>
      <div class="header-badges">
        <span class="badge" style={`background: ${kategoriefarben[technik.kategorie]}`}>{technik.kategorie}</span>
        <span class="header-meta">{technik.schwierigkeit} · Prüfungsrelevant ab {technik.kyu}. Kyu</span>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="detail-grid">
      <KihonIllustration technikId={technik.id} kategorie={technik.kategorie} nameJP={technik.nameJP} />

      <div class="detail-content">
        <div class="info-stats">
          <div class="stat-item">
            <span class="stat-label">Kategorie</span>
            <span class="badge" style={`background: ${kategoriefarben[technik.kategorie]}`}>{technik.kategorie}</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">Schwierigkeit</span>
            <span class="stat-value">{technik.schwierigkeit}</span>
          </div>
          <div class="stat-item">
            <span class="stat-label">Ab Kyu</span>
            <span class="stat-value">{technik.kyu}. Kyu</span>
          </div>
        </div>

        <div class="info-box">
          <h2>Ausführung</h2>
          <p>{technik.beschreibung}</p>
        </div>
      </div>
    </div>

    {verwandte.length > 0 && (
      <div class="verwandte">
        <h2 class="section-title">Weitere {technik.kategorie}-Techniken</h2>
        <div class="grid-3">
          {verwandte.map(v => (
            <a href={`${base}kihon/${v.id}`} class="card verwandte-card">
              <span class="badge" style={`background: ${kategoriefarben[v.kategorie]}`}>{v.kategorie}</span>
              <p class="vk-jp">{v.nameJP} <span class="romanisch">({toRomanisch(v.id)})</span></p>
              <p class="vk-name">{v.nameDE}</p>
              <p class="vk-desc">{v.beschreibung.slice(0, 80)}…</p>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</Layout>

<style>

  .detail-grid { display: grid; grid-template-columns: 320px 1fr; gap: 3rem; margin-bottom: 4rem; }

  .info-stats {
    display: flex;
    gap: 2rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .stat-item { display: flex; flex-direction: column; gap: 0.35rem; }
  .stat-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); font-weight: 600; }
  .stat-value { font-size: 0.9rem; font-weight: 500; }

  .info-box { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; }
  .info-box h2 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 0.75rem; font-weight: 700; }
  .info-box p { line-height: 1.8; font-size: 0.95rem; }

  .verwandte-card { display: block; }
  .vk-jp { font-size: 1.4rem; color: var(--primary); margin: 0.5rem 0 0.2rem; line-height: 1; }
  .vk-name { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.5rem; }
  .vk-desc { font-size: 0.8rem; color: var(--text-muted); line-height: 1.5; }

  @media (max-width: 768px) { .detail-grid { grid-template-columns: 1fr; } }
</style>
