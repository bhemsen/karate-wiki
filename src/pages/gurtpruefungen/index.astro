---
import Layout from '../../layouts/Layout.astro';
import { gurtpruefungen } from '../../data/gurtpruefungen';
const base = import.meta.env.BASE_URL;
---
<Layout title="Gurtprüfungen – JKA Shotokan" description="JKA Shotokan Gurtprüfungsanforderungen von 9. Kyu (Weiß zu Gelb) bis 1. Dan (Shodan).">
  <div class="page-header">
    <div class="page-header-inner">
      <p class="breadcrumb"><a href={base}>Startseite</a> › Gurtprüfungen</p>
      <h1>帯 Gurtprüfungen</h1>
      <p class="subtitle">JKA-Standard · 9. Kyu bis 1. Dan · Shotokan Karate</p>
    </div>
  </div>

  <div class="container">
    <div class="pruefungen-list">
      {gurtpruefungen.map((p, i) => (
        <div class="pruefung-card">
          <div class="pruefung-header">
            <div class="gurt-visual">
              <div class="gurt-streifen" style={`background: ${p.gurtHex}`}></div>
              {p.kyu === 0 && <div class="dan-badge">黒帯</div>}
            </div>
            <div>
              <h2 class="pruefung-titel">{p.pruefungsname}</h2>
              <p class="pruefung-meta">{p.gurtfarbe} · Mindesttraining: {p.mindestTrainingszeit} Monate</p>
            </div>
          </div>

          <div class="pruefung-body">
            <div class="anforderung-block">
              <h3>Kihon-Anforderungen</h3>
              <ul>
                {p.kihonAnforderungen.map(k => <li>{k}</li>)}
              </ul>
            </div>
            <div class="anforderung-block">
              <h3>Kata</h3>
              <ul>
                {p.kata.map(k => (
                  <li>
                    {k.includes('(') ? k : <a href={`${base}kata/${k.toLowerCase().replace(/\s+/g, '-').replace('ä','ae').replace('ö','oe').replace('ü','ue')}`}>{k}</a>}
                  </li>
                ))}
              </ul>
            </div>
            <div class="anforderung-block">
              <h3>Kumite</h3>
              <p>{p.kumite}</p>
            </div>
            <div class="anforderung-block">
              <h3>Weitere Anforderungen</h3>
              <p>{p.sonstigeAnforderungen}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="quellen-box">
      <h2>Quellen & Hinweise</h2>
      <p>Die Anforderungen basieren auf dem JKA-Standard (Japan Karate Association). Regionale Verbände (DKV, DJKB) können abweichende Regelungen haben. Maßgeblich ist immer die Prüfungsordnung des eigenen Verbandes und die Einschätzung des Sensei.</p>
    </div>
  </div>
</Layout>

<style>
  h1 { font-size: 2rem; margin-bottom: .25rem; }
  .subtitle { color: var(--text-muted); font-size: .9rem; }
  .pruefungen-list { display: flex; flex-direction: column; gap: 1.5rem; }
  .pruefung-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .pruefung-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .gurt-visual { position: relative; display: flex; align-items: center; justify-content: center; }
  .gurt-streifen {
    width: 48px;
    height: 12px;
    border-radius: 6px;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
  }
  .dan-badge {
    position: absolute;
    font-size: .6rem;
    color: #fff;
    font-weight: 700;
    font-family: 'Montserrat', sans-serif;
  }
  .pruefung-titel { font-size: 1.1rem; margin-bottom: .1rem; }
  .pruefung-meta { font-size: .8rem; color: var(--text-muted); }
  .pruefung-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }
  .anforderung-block {
    padding: 1.25rem 1.5rem;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .anforderung-block:nth-child(even) { border-right: none; }
  .anforderung-block:nth-last-child(-n+2) { border-bottom: none; }
  .anforderung-block h3 { font-size: .8rem; text-transform: uppercase; letter-spacing: .05em; color: var(--text-muted); margin-bottom: .75rem; }
  .anforderung-block ul { list-style: none; display: flex; flex-direction: column; gap: .35rem; }
  .anforderung-block li { font-size: .875rem; display: flex; gap: .5rem; align-items: flex-start; }
  .anforderung-block li::before { content: '›'; color: var(--primary); flex-shrink: 0; }
  .anforderung-block p { font-size: .875rem; line-height: 1.6; color: var(--text-muted); }
  .anforderung-block a { color: var(--primary); }
  .anforderung-block a:hover { text-decoration: underline; }
  .quellen-box {
    margin-top: 3rem;
    background: #FFF8F7;
    border: 1px solid #FECACA;
    border-radius: var(--radius);
    padding: 1.5rem;
  }
  .quellen-box h2 { font-size: 1rem; margin-bottom: .75rem; color: var(--primary); }
  .quellen-box p { font-size: .875rem; line-height: 1.7; color: var(--text-muted); }
  @media (max-width: 768px) { .pruefung-body { grid-template-columns: 1fr; } .anforderung-block { border-right: none; } }
</style>
