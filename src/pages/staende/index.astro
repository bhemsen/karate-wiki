---
import Layout from '../../layouts/Layout.astro';
import { dachi, type Schwierigkeit } from '../../data/dachi';
const base = import.meta.env.BASE_URL;
const schwierigkeitFarbe: Record<Schwierigkeit, string> = {
  'Anfänger': '#27AE60', 'Mittel': '#E67E22', 'Fortgeschritten': '#C0392B'
};
---
<Layout title="Stände – Dachi" description="Alle 12 Shotokan Stände (Dachi) mit Erklärung von Fußstellung, Gewichtsverteilung und Anwendung.">
  <div class="page-header">
    <div class="page-header-inner">
      <p class="breadcrumb"><a href={base}>Startseite</a> › Stände</p>
      <h1>立ち Dachi – Stände</h1>
      <p class="subtitle">{dachi.length} Grundstände im Shotokan Karate</p>
    </div>
  </div>

  <div class="container">
    <div class="grid-2">
      {dachi.map(d => (
        <a href={`${base}staende/${d.id}`} class="card stand-card">
          <div class="card-header">
            <span class="badge" style={`background: ${schwierigkeitFarbe[d.schwierigkeit]}`}>{d.schwierigkeit}</span>
          </div>
          <p class="stand-jp">{d.nameJP}</p>
          <h2 class="stand-name">{d.nameDE}</h2>
          <p class="stand-desc">{d.beschreibung.slice(0, 130)}…</p>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  h1 { font-size: 2rem; margin-bottom: .25rem; }
  .subtitle { color: var(--text-muted); font-size: .9rem; }
  .card-header { margin-bottom: .75rem; }
  .stand-jp { font-size: 1.75rem; color: var(--primary); line-height: 1; margin-bottom: .25rem; }
  .stand-name { font-size: 1.05rem; margin-bottom: .75rem; }
  .stand-desc { font-size: .875rem; color: var(--text-muted); line-height: 1.6; }
</style>
