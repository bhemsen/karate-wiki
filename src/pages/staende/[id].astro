---
import Layout from '../../layouts/Layout.astro';
import { dachi, type Schwierigkeit } from '../../data/dachi';

export function getStaticPaths() {
  return dachi.map(d => ({ params: { id: d.id }, props: { stand: d } }));
}

const { stand } = Astro.props;
const base = import.meta.env.BASE_URL;
const schwierigkeitFarbe: Record<Schwierigkeit, string> = {
  'Anfänger': '#27AE60', 'Mittel': '#E67E22', 'Fortgeschritten': '#C0392B'
};
const andere = dachi.filter(d => d.id !== stand.id).slice(0, 4);
---
<Layout title={`${stand.nameDE} (${stand.nameJP})`} description={stand.beschreibung}>
  <div class="page-header">
    <div class="page-header-inner">
      <p class="breadcrumb">
        <a href={base}>Startseite</a>
        <span class="sep">›</span>
        <a href={`${base}staende`}>Stände</a>
        <span class="sep">›</span>
        {stand.nameDE}
      </p>
      <h1>{stand.nameJP} <span class="h1-de">{stand.nameDE}</span></h1>
      <div class="header-badges">
        <span class="badge" style={`background: ${schwierigkeitFarbe[stand.schwierigkeit]}`}>{stand.schwierigkeit}</span>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="detail-grid">
      <div class="detail-content">
        <div class="info-box">
          <h2>Beschreibung</h2>
          <p>{stand.beschreibung}</p>
        </div>

        <div class="meta-grid">
          <div class="meta-item">
            <span class="meta-label">Japanisch</span>
            <span class="meta-jp">{stand.nameJP}</span>
          </div>
          <div class="meta-item">
            <span class="meta-label">Deutsch</span>
            <span class="meta-value">{stand.nameDE}</span>
          </div>
          <div class="meta-item">
            <span class="meta-label">Schwierigkeit</span>
            <span class="badge" style={`background: ${schwierigkeitFarbe[stand.schwierigkeit]}`}>{stand.schwierigkeit}</span>
          </div>
        </div>
      </div>

      <div class="sidebar">
        <div class="illustration-box">
          <div class="illustration-placeholder">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="5" r="2.5"/>
              <path d="M12 8v5m0 0-3 4m3-4 3 4"/>
            </svg>
            <p class="ill-label">Illustration</p>
            <p class="ill-jp">{stand.nameJP}</p>
          </div>
        </div>

        <div class="verwandte-box">
          <h3>Weitere Stände</h3>
          <ul class="verwandte-list">
            {andere.map(d => (
              <li>
                <a href={`${base}staende/${d.id}`}>
                  <span class="vk-jp">{d.nameJP}</span>
                  <span class="vk-de">{d.nameDE}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .h1-de { font-size: 1.1rem; font-weight: 400; opacity: 0.65; margin-left: 0.5rem; }

  .detail-grid { display: grid; grid-template-columns: 1fr 340px; gap: 3rem; }

  .info-box { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; margin-bottom: 1.5rem; }
  .info-box h2 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 0.75rem; font-weight: 700; }
  .info-box p { line-height: 1.85; font-size: 0.95rem; }

  .meta-grid {
    display: flex;
    gap: 2.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    flex-wrap: wrap;
  }
  .meta-item { display: flex; flex-direction: column; gap: 0.35rem; }
  .meta-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); font-weight: 600; }
  .meta-jp { font-size: 1.5rem; color: var(--primary); line-height: 1; }
  .meta-value { font-size: 0.9rem; font-weight: 500; }

  .illustration-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 1rem;
  }
  .illustration-placeholder {
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: var(--text-muted);
    background: #F5F7F8;
  }
  .illustration-placeholder svg { opacity: 0.25; }
  .ill-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; }
  .ill-jp { font-size: 1.5rem; color: var(--primary); opacity: 0.4; line-height: 1; }

  .verwandte-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
  }
  .verwandte-box h3 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 0.75rem; font-weight: 700; }
  .verwandte-list { list-style: none; display: flex; flex-direction: column; gap: 0.25rem; }
  .verwandte-list a {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.5rem 0.5rem;
    border-radius: 4px;
    transition: background 0.15s;
  }
  .verwandte-list a:hover { background: #FFF5F4; }
  .vk-jp { font-size: 1.1rem; color: var(--primary); font-weight: 500; line-height: 1.2; }
  .vk-de { font-size: 0.8rem; color: var(--text-muted); }

  @media (max-width: 900px) { .detail-grid { grid-template-columns: 1fr; } }
</style>
