---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
const bereiche = [
  { href: `${base}kihon`, kanji: '基本', titel: 'Kihon', desc: '17 Grundtechniken: Stöße, Blöcke und Tritte mit Schritt-für-Schritt-Erklärung' },
  { href: `${base}kata`, kanji: '型', titel: 'Kata', desc: 'Alle 26 Shotokan-Kata mit Bedeutung, Bewegungsanzahl und Schwierigkeit' },
  { href: `${base}staende`, kanji: '立ち', titel: 'Stände', desc: '12 Dachi erklärt: Fußstellung, Gewichtsverteilung und Anwendungskontext' },
  { href: `${base}gurtpruefungen`, kanji: '帯', titel: 'Gurtprüfungen', desc: 'JKA-Standard von 9. Kyu (Weiß) bis 1. Dan mit allen Anforderungen' },
  { href: `${base}glossar`, kanji: '語彙', titel: 'Glossar', desc: 'Über 60 japanische Begriffe aus Technik, Philosophie und Dojo-Etikette' },
];
---
<Layout title="Startseite">
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow">空手道 · Shotokan · JKA-Standard</p>
      <h1 class="hero-title">Die vollständige<br/><span class="accent">Karate Referenz</span></h1>
      <p class="hero-subtitle">Techniken, Kata, Stände, Gurtprüfungen und Glossar – strukturiert, klar und auf Deutsch.</p>
      <div class="hero-actions">
        <a href={`${base}kihon`} class="btn-primary">Techniken erkunden</a>
        <a href={`${base}glossar`} class="btn-secondary">Zum Glossar</a>
      </div>
    </div>
  </section>

  <section class="container">
    <h2 class="section-title">Alle Bereiche</h2>
    <div class="bereiche-grid">
      {bereiche.map(b => (
        <a href={b.href} class="bereich-card">
          <span class="bereich-kanji">{b.kanji}</span>
          <div>
            <h3 class="bereich-titel">{b.titel}</h3>
            <p class="bereich-desc">{b.desc}</p>
          </div>
          <span class="bereich-arrow">→</span>
        </a>
      ))}
    </div>
  </section>

  <section class="info-section">
    <div class="container">
      <div class="info-grid">
        <div>
          <h2>Über diese Referenz</h2>
          <p>Diese Seite basiert auf dem JKA-Standard (Japan Karate Association) und orientiert sich an Masatoshi Nakayamas <em>Best Karate</em>-Serie sowie Hirokazu Kanazawas Lehrwerken. Sie richtet sich an Karateka aller Stufen – vom Anfänger bis zum Dan-Träger.</p>
        </div>
        <div class="info-stats">
          <div class="stat"><span class="stat-num">17</span><span>Kihon-Techniken</span></div>
          <div class="stat"><span class="stat-num">26</span><span>Kata</span></div>
          <div class="stat"><span class="stat-num">12</span><span>Stände</span></div>
          <div class="stat"><span class="stat-num">10</span><span>Prüfungsstufen</span></div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, #2C3E50 0%, #1a252f 100%);
    color: #fff;
    padding: 6rem 2rem;
  }
  .hero-inner { max-width: 800px; margin: 0 auto; }
  .hero-eyebrow {
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    color: #C0392B;
    font-weight: 600;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }
  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }
  .accent { color: #C0392B; }
  .hero-subtitle {
    font-size: 1.1rem;
    color: #94A3B8;
    max-width: 540px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary {
    background: #C0392B;
    color: #fff;
    padding: 0.75rem 1.75rem;
    border-radius: 6px;
    font-weight: 600;
    font-family: 'Montserrat', sans-serif;
    transition: background 0.15s;
  }
  .btn-primary:hover { background: #96281B; }
  .btn-secondary {
    background: rgba(255,255,255,0.1);
    color: #fff;
    padding: 0.75rem 1.75rem;
    border-radius: 6px;
    font-weight: 600;
    font-family: 'Montserrat', sans-serif;
    border: 1px solid rgba(255,255,255,0.2);
    transition: background 0.15s;
  }
  .btn-secondary:hover { background: rgba(255,255,255,0.2); }

  .section-title {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .bereiche-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .bereich-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .bereich-card:hover {
    border-color: var(--primary);
    box-shadow: 0 4px 16px rgba(192,57,43,0.08);
  }
  .bereich-kanji {
    font-size: 2rem;
    color: var(--primary);
    min-width: 3rem;
    text-align: center;
    line-height: 1;
  }
  .bereich-titel {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .bereich-desc { font-size: 0.9rem; color: var(--text-muted); }
  .bereich-arrow { margin-left: auto; color: var(--primary); font-size: 1.25rem; }

  .info-section { background: var(--surface); border-top: 1px solid var(--border); }
  .info-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
  }
  .info-grid h2 { font-size: 1.5rem; margin-bottom: 1rem; }
  .info-grid p { color: var(--text-muted); line-height: 1.8; }
  .info-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .stat-num {
    font-family: 'Montserrat', sans-serif;
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--primary);
    line-height: 1;
  }
  .stat span:last-child { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.25rem; }

  @media (max-width: 768px) {
    .info-grid { grid-template-columns: 1fr; }
    .info-stats { grid-template-columns: repeat(4, 1fr); }
  }
</style>
