---
import Layout from '../../layouts/Layout.astro';
import { kata, type Schwierigkeit, type Gruppe } from '../../data/kata';
const base = import.meta.env.BASE_URL;

const schwierigkeitFarbe: Record<Schwierigkeit, string> = {
  'Anfänger': '#27AE60', 'Mittel': '#E67E22', 'Fortgeschritten': '#C0392B', 'Meister': '#8E44AD'
};
const gruppenFarbe: Record<Gruppe, string> = {
  'Heian': '#C0392B', 'Tekki': '#8B1A1A', 'Shorin': '#2980B9', 'Shorei': '#8E44AD', 'Sonstige': '#7F8C8D'
};
const gruppen: Gruppe[] = ['Heian', 'Tekki', 'Shorin', 'Shorei', 'Sonstige'];
---
<Layout title="Kata – Alle 26 Shotokan Kata" description="Alle 26 offiziellen Shotokan Kata mit Bedeutung, Bewegungsanzahl, Schwierigkeit und Beschreibung.">
  <div class="page-header">
    <div class="page-header-inner">
      <p class="breadcrumb"><a href={base}>Startseite</a> <span class="sep">›</span> Kata</p>
      <h1><span class="jp">型</span> Kata</h1>
      <p class="subtitle">{kata.length} Shotokan-Kata · JKA-Standard · nach Gruppe geordnet</p>
    </div>
  </div>

  <div class="container">
    <div class="filter-bar" id="filter-bar">
      <button class="filter-btn active" data-gruppe="alle">Alle ({kata.length})</button>
      {gruppen.map(g => (
        <button class="filter-btn" data-gruppe={g}>{g} ({kata.filter(k => k.gruppe === g).length})</button>
      ))}
    </div>

    <div class="grid-4" id="kata-grid">
      {kata.map(k => (
        <a href={`${base}kata/${k.id}`} class="card kata-card" data-gruppe={k.gruppe}>
          <div class="kata-stripe" style={`background: ${gruppenFarbe[k.gruppe]}`}></div>
          <div class="card-body">
            <div class="card-top">
              <span class="gruppe-badge" style={`background: ${gruppenFarbe[k.gruppe]}`}>{k.gruppe}</span>
              <span class="schwierigkeit-badge" style={`background: ${schwierigkeitFarbe[k.schwierigkeit]}`}>{k.schwierigkeit}</span>
            </div>
            <h2 class="kata-name">{k.name}</h2>
            <p class="kata-bedeutung">„{k.bedeutung}"</p>
            <div class="kata-meta">
              <span>{k.bewegungsanzahl} Bewegungen</span>
              <span class="sep">·</span>
              <span>Ab {k.erstePruefung}</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .grid-4 { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; }
  .kata-card { padding: 0; overflow: hidden; }
  .kata-stripe { height: 3px; width: 100%; }
  .card-body { padding: 1.25rem; }
  .card-top { display: flex; gap: 0.5rem; margin-bottom: 0.75rem; align-items: center; flex-wrap: wrap; }
  .gruppe-badge, .schwierigkeit-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    color: #fff;
  }
  .kata-name { font-size: 1rem; font-weight: 700; margin-bottom: 0.25rem; }
  .kata-bedeutung { font-size: 0.78rem; color: var(--primary); font-style: italic; margin-bottom: 0.75rem; }
  .kata-meta { display: flex; gap: 0.4rem; font-size: 0.75rem; color: var(--text-muted); align-items: center; }
  .kata-card[hidden] { display: none; }
  .sep { opacity: 0.4; }

  @media (max-width: 480px) { .grid-4 { grid-template-columns: 1fr 1fr; } }
</style>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('#filter-bar .filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('#kata-grid .kata-card');
  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const gruppe = btn.dataset.gruppe;
      cards.forEach(card => { card.hidden = gruppe !== 'alle' && card.dataset.gruppe !== gruppe; });
    });
  });
</script>
