---
import Layout from '../../layouts/Layout.astro';
import { kata, type Schwierigkeit } from '../../data/kata';
import { kataAblaufMap } from '../../data/kata-ablauf';
import EmbusenDiagramm from '../../components/EmbusenDiagramm.astro';

export function getStaticPaths() {
  return kata.map(k => ({ params: { id: k.id }, props: { eintrag: k } }));
}

const { eintrag } = Astro.props;
const base = import.meta.env.BASE_URL;
const schwierigkeitFarbe: Record<Schwierigkeit, string> = {
  'Anfänger': '#27AE60', 'Mittel': '#E67E22', 'Fortgeschritten': '#C0392B', 'Meister': '#8E44AD'
};
const verwandte = kata.filter(k => k.gruppe === eintrag.gruppe && k.id !== eintrag.id).slice(0, 4);
const ablauf = kataAblaufMap[eintrag.id];
---
<Layout title={`${eintrag.name}`} description={eintrag.beschreibung}>
  <div class="page-header">
    <div class="page-header-inner">
      <p class="breadcrumb">
        <a href={base}>Startseite</a>
        <span class="sep">›</span>
        <a href={`${base}kata`}>Kata</a>
        <span class="sep">›</span>
        {eintrag.name}
      </p>
      <h1>{eintrag.name}</h1>
      <p class="subtitle">„{eintrag.bedeutung}"</p>
      <div class="header-badges">
        <span class="badge" style={`background: ${schwierigkeitFarbe[eintrag.schwierigkeit]}`}>{eintrag.schwierigkeit}</span>
        <span class="header-meta">{eintrag.gruppe}-Kata · {eintrag.bewegungsanzahl} Bewegungen · Ab {eintrag.erstePruefung}</span>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="detail-grid">
      <div>
        <div class="kata-stats-box">
          <div class="stat-item">
            <span class="stat-kanji">{eintrag.name.split(' ')[0]}</span>
            <span class="stat-label">Japanischer Name</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">{eintrag.bewegungsanzahl}</span>
            <span class="stat-label">Bewegungen</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">{eintrag.erstePruefung}</span>
            <span class="stat-label">Erste Prüfung</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">{eintrag.gruppe}</span>
            <span class="stat-label">Gruppe</span>
          </div>
        </div>

        <div class="info-box">
          <h2>Über diese Kata</h2>
          <p>{eintrag.beschreibung}</p>
        </div>
      </div>

      <div>
        <EmbusenDiagramm kataId={eintrag.id} name={eintrag.name} />

        {verwandte.length > 0 && (
          <div class="verwandte-box">
            <h3>Weitere {eintrag.gruppe}-Kata</h3>
            <ul class="verwandte-list">
              {verwandte.map(v => (
                <li>
                  <a href={`${base}kata/${v.id}`}>
                    <span class="vk-name">{v.name}</span>
                    <span class="vk-meta">{v.bewegungsanzahl} Bew.</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>

    <div class="ablauf-section">
      <h2 class="section-title">Technik-Abfolge</h2>

      {!ablauf || ablauf.schritte.length === 0 ? (
        <div class="ablauf-empty">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <circle cx="12" cy="12" r="10"/>
            <path d="M12 8v4m0 4h.01"/>
          </svg>
          <p>Die detaillierte Technik-Abfolge für diese Kata wird noch ergänzt.</p>
        </div>
      ) : (
        <div>
          {!ablauf.vollstaendig && (
            <div class="ablauf-hinweis">
              Wichtigste Schlüsseltechniken — vollständige Abfolge wird ergänzt
            </div>
          )}
          <div class="ablauf-list">
            {ablauf.schritte.map(schritt => (
              <div class={`ablauf-schritt${schritt.kiai ? ' kiai' : ''}`}>
                <div class="schritt-nr">
                  {schritt.kiai
                    ? <span class="kiai-badge" title="Kiai">気</span>
                    : <span>{schritt.nr}</span>
                  }
                </div>
                <div class="schritt-body">
                  <div class="schritt-head">
                    <span class="schritt-technik">{schritt.technik}</span>
                    <div class="schritt-tags">
                      <span class={`tag-seite seite-${schritt.seite.toLowerCase()}`}>{schritt.seite}</span>
                      <span class="tag-stand">{schritt.stand}</span>
                      <span class="tag-richtung">{schritt.richtung}</span>
                    </div>
                  </div>
                  <p class="schritt-desc">{schritt.beschreibung}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .detail-grid { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; margin-bottom: 4rem; }

  .kata-stats-box {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 1.5rem;
  }
  .stat-item {
    padding: 1.25rem 1.5rem;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .stat-item:nth-child(even) { border-right: none; }
  .stat-item:nth-last-child(-n+2) { border-bottom: none; }
  .stat-kanji { font-size: 1.4rem; color: var(--primary); font-family: var(--font-head); font-weight: 700; line-height: 1; }
  .stat-num { font-size: 1.25rem; font-weight: 700; font-family: var(--font-head); color: var(--text); }
  .stat-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); font-weight: 600; }

  .info-box { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; }
  .info-box h2 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 0.75rem; font-weight: 700; }
  .info-box p { line-height: 1.85; font-size: 0.95rem; }

  .verwandte-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
  }
  .verwandte-box h3 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 0.75rem; font-weight: 700; }
  .verwandte-list { list-style: none; display: flex; flex-direction: column; gap: 0.25rem; }
  .verwandte-list a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 0.5rem;
    border-radius: 4px;
    font-size: 0.875rem;
    color: var(--primary);
    transition: background 0.15s;
  }
  .verwandte-list a:hover { background: #FFF5F4; }
  .vk-name { font-weight: 500; }
  .vk-meta { font-size: 0.75rem; color: var(--text-muted); }

  /* ── Technik-Abfolge ── */
  .ablauf-section { padding-bottom: 4rem; }

  .ablauf-hinweis {
    font-size: 0.8rem;
    color: #92400E;
    background: #FFFBEB;
    border: 1px solid #FDE68A;
    border-radius: var(--radius);
    padding: 0.6rem 1rem;
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .ablauf-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 3rem 2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text-muted);
    text-align: center;
  }
  .ablauf-empty svg { opacity: 0.3; }
  .ablauf-empty p { font-size: 0.9rem; }

  .ablauf-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .ablauf-schritt {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--border);
    transition: background 0.1s;
  }
  .ablauf-schritt:last-child { border-bottom: none; }
  .ablauf-schritt:hover { background: #FAFAFA; }
  .ablauf-schritt.kiai { background: #FFF5F4; }
  .ablauf-schritt.kiai:hover { background: #FEE9E7; }

  .schritt-nr {
    width: 56px;
    flex-shrink: 0;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 1rem 0;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-muted);
    border-right: 1px solid var(--border);
    font-family: var(--font-head);
  }
  .kiai-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--primary);
    color: #fff;
    border-radius: 50%;
    font-size: 0.85rem;
    font-family: var(--font-head);
    font-weight: 700;
    line-height: 1;
    margin-top: 0.1rem;
  }

  .schritt-body {
    flex: 1;
    padding: 0.9rem 1.25rem;
    min-width: 0;
  }

  .schritt-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.4rem;
  }

  .schritt-technik {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
    font-family: var(--font-head);
  }

  .schritt-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag-seite, .tag-stand, .tag-richtung {
    font-size: 0.68rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .tag-seite { background: #EEF2FF; color: #4338CA; }
  .tag-seite.seite-rechts { background: #FFF7ED; color: #C2410C; }
  .tag-seite.seite-beide { background: #F0FDF4; color: #15803D; }
  .tag-stand { background: #F1F5F9; color: #475569; }
  .tag-richtung { background: #F8FAFC; color: #64748B; }

  .schritt-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin: 0;
  }

  @media (max-width: 900px) { .detail-grid { grid-template-columns: 1fr; } }
  @media (max-width: 600px) {
    .schritt-nr { width: 44px; }
    .schritt-body { padding: 0.75rem 1rem; }
  }
</style>
