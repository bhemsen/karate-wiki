---
import Layout from '../../layouts/Layout.astro';
import { kata, type Schwierigkeit } from '../../data/kata';

export function getStaticPaths() {
  return kata.map(k => ({ params: { id: k.id }, props: { eintrag: k } }));
}

const { eintrag } = Astro.props;
const base = import.meta.env.BASE_URL;
const schwierigkeitFarbe: Record<Schwierigkeit, string> = {
  'Anfänger': '#27AE60', 'Mittel': '#E67E22', 'Fortgeschritten': '#C0392B', 'Meister': '#8E44AD'
};
const verwandte = kata.filter(k => k.gruppe === eintrag.gruppe && k.id !== eintrag.id).slice(0, 4);
---
<Layout title={`${eintrag.name}`} description={eintrag.beschreibung}>
  <div class="page-header">
    <div class="page-header-inner">
      <p class="breadcrumb">
        <a href={base}>Startseite</a>
        <span class="sep">›</span>
        <a href={`${base}kata`}>Kata</a>
        <span class="sep">›</span>
        {eintrag.name}
      </p>
      <h1>{eintrag.name}</h1>
      <p class="subtitle">„{eintrag.bedeutung}"</p>
      <div class="header-badges">
        <span class="badge" style={`background: ${schwierigkeitFarbe[eintrag.schwierigkeit]}`}>{eintrag.schwierigkeit}</span>
        <span class="header-meta">{eintrag.gruppe}-Kata · {eintrag.bewegungsanzahl} Bewegungen · Ab {eintrag.erstePruefung}</span>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="detail-grid">
      <div>
        <div class="kata-stats-box">
          <div class="stat-item">
            <span class="stat-kanji">{eintrag.name.split(' ')[0]}</span>
            <span class="stat-label">Japanischer Name</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">{eintrag.bewegungsanzahl}</span>
            <span class="stat-label">Bewegungen</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">{eintrag.erstePruefung}</span>
            <span class="stat-label">Erste Prüfung</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">{eintrag.gruppe}</span>
            <span class="stat-label">Gruppe</span>
          </div>
        </div>

        <div class="info-box">
          <h2>Über diese Kata</h2>
          <p>{eintrag.beschreibung}</p>
        </div>
      </div>

      <div>
        <div class="illustration-box">
          <div class="illustration-placeholder">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="5" r="2.5"/>
              <path d="M12 8v5m0 0-3 4m3-4 3 4"/>
            </svg>
            <p class="ill-label">Embusen</p>
            <p class="ill-name">{eintrag.name}</p>
          </div>
        </div>

        {verwandte.length > 0 && (
          <div class="verwandte-box">
            <h3>Weitere {eintrag.gruppe}-Kata</h3>
            <ul class="verwandte-list">
              {verwandte.map(v => (
                <li>
                  <a href={`${base}kata/${v.id}`}>
                    <span class="vk-name">{v.name}</span>
                    <span class="vk-meta">{v.bewegungsanzahl} Bew.</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  </div>
</Layout>

<style>
  .detail-grid { display: grid; grid-template-columns: 1fr 380px; gap: 3rem; }

  .kata-stats-box {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 1.5rem;
  }
  .stat-item {
    padding: 1.25rem 1.5rem;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .stat-item:nth-child(even) { border-right: none; }
  .stat-item:nth-last-child(-n+2) { border-bottom: none; }
  .stat-kanji { font-size: 1.4rem; color: var(--primary); font-family: var(--font-head); font-weight: 700; line-height: 1; }
  .stat-num { font-size: 1.25rem; font-weight: 700; font-family: var(--font-head); color: var(--text); }
  .stat-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); font-weight: 600; }

  .info-box { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.5rem; }
  .info-box h2 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 0.75rem; font-weight: 700; }
  .info-box p { line-height: 1.85; font-size: 0.95rem; }

  .illustration-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 1rem;
  }
  .illustration-placeholder {
    aspect-ratio: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: var(--text-muted);
    background: #F5F7F8;
  }
  .illustration-placeholder svg { opacity: 0.25; }
  .ill-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; }
  .ill-name { font-size: 0.85rem; color: var(--primary); }

  .verwandte-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
  }
  .verwandte-box h3 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); margin-bottom: 0.75rem; font-weight: 700; }
  .verwandte-list { list-style: none; display: flex; flex-direction: column; gap: 0.25rem; }
  .verwandte-list a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.4rem 0.5rem;
    border-radius: 4px;
    font-size: 0.875rem;
    color: var(--primary);
    transition: background 0.15s;
  }
  .verwandte-list a:hover { background: #FFF5F4; }
  .vk-name { font-weight: 500; }
  .vk-meta { font-size: 0.75rem; color: var(--text-muted); }

  @media (max-width: 900px) { .detail-grid { grid-template-columns: 1fr; } }
</style>
